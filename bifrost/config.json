{
  "$schema": "https://www.getbifrost.ai/schema",
  "encryption_key": "env.BIFROST_ENCRYPTION_KEY",
  "client": {
    "drop_excess_requests": false,
    "prometheus_labels": ["api_key"],
    "compat": {
      "should_drop_params": true
    }
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  },
  "framework": {
    "pricing": {
      "pricing_url": "file:///app/data/datasheet.json",
      "model_parameters_url": "file:///app/data/model-parameters.json",
      "mcp_library_url": "file:///app/data/mcp-library.json"
    }
  }
}
