{
  "uid": "unibridge-llm",
  "title": "UniBridge \u00b7 LLM Monitoring",
  "tags": [
    "unibridge"
  ],
  "timezone": "Asia/Seoul",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "api_key",
        "label": "API key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(litellm_total_tokens_metric_total, end_user)",
          "refId": "var-api_key"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "sort": 1
      },
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "interval",
        "auto": true,
        "auto_count": 500,
        "auto_min": "30s",
        "query": "1h,1d,1w",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "auto",
          "value": "$__auto_interval_bucket"
        },
        "options": [
          {
            "selected": true,
            "text": "auto",
            "value": "$__auto_interval_bucket"
          },
          {
            "selected": false,
            "text": "1h",
            "value": "1h"
          },
          {
            "selected": false,
            "text": "1d",
            "value": "1d"
          },
          {
            "selected": false,
            "text": "1w",
            "value": "1w"
          }
        ]
      }
    ]
  },
