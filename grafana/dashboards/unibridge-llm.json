        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false
        },
        "sortBy": [
          {
            "displayName": "Total tokens",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value #A": "Total tokens",
              "Value #B": "Input",
              "Value #C": "Output",
              "Value #D": "Cached",
              "Value #E": "Requests",
              "Value #F": "Cost"
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "((sum by (requested_model, model) (increase(litellm_total_tokens_metric_total{end_user=~\"$api_key\"}[$__range])) > 0) or (sum by (requested_model, model) (increase(litellm_input_tokens_metric_total{end_user=~\"$api_key\"}[$__range])) + sum by (requested_model, model) (increase(litellm_output_tokens_metric_total{end_user=~\"$api_key\"}[$__range]))) or sum by (requested_model, model) (increase(litellm_input_tokens_metric_total{end_user=~\"$api_key\"}[$__range])) or sum by (requested_model, model) (increase(litellm_output_tokens_metric_total{end_user=~\"$api_key\"}[$__range])) or (sum by (requested_model, model) (increase(litellm_proxy_total_requests_metric_total{end_user=~\"$api_key\"}[$__range])) * 0))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "sum by (requested_model, model) (increase(litellm_input_tokens_metric_total{end_user=~\"$api_key\"}[$__range]))",
          "datasource": {
