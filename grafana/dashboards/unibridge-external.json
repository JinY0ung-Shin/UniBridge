        {
          "refId": "C",
          "expr": "(histogram_quantile(0.5, sum by (service, le) (rate(http_request_duration_seconds_bucket{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\"}[$__range]))) * 1000) and on (service) topk(10, sum by (service) (increase(http_requests_total{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\"}[$__range])) or sum by (service) (increase(http_request_duration_seconds_count{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\"}[$__range])))",
