        {
          "refId": "B",
          "expr": "(sum by (service) (increase(http_requests_total{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\",status=~\"5..\"}[$__range])) or sum by (service) (increase(http_request_duration_seconds_count{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\",status=~\"5..\"}[$__range]))) and on (service) topk(10, sum by (service) (increase(http_requests_total{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\"}[$__range])) or sum by (service) (increase(http_request_duration_seconds_count{job=\"external-services\",service=~\"$service\",handler=~\"$endpoint\"}[$__range])))",
