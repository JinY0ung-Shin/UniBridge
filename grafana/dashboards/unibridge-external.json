{
  "uid": "unibridge-external",
  "title": "UniBridge \u00b7 External API Monitoring",
  "tags": [
    "unibridge"
  ],
  "timezone": "Asia/Seoul",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(up{job=\"external-services\"}, service)",
          "refId": "var-service"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "sort": 1
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values({__name__=~\"http_requests_total|http_request_duration_seconds_count\",job=\"external-services\",service=~\"$service\"}, handler)",
          "refId": "var-endpoint"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "sort": 1
      }
    ]
  },
  "panels": [
