{
  "uid": "unibridge-gateway",
  "title": "UniBridge \u00b7 Gateway Monitoring",
  "tags": [
    "unibridge"
  ],
  "timezone": "Asia/Seoul",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\"}, route)",
          "refId": "var-route"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "sort": 1
      },
      {
        "name": "consumer",
        "label": "API key (consumer)",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\"}, consumer)",
          "refId": "var-consumer"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "sort": 1
      },
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "interval",
        "auto": true,
        "auto_count": 500,
        "auto_min": "30s",
        "query": "1h,1d,1w",
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "auto",
          "value": "$__auto_interval_bucket"
        },
        "options": [
          {
            "selected": true,
            "text": "auto",
            "value": "$__auto_interval_bucket"
          },
          {
            "selected": false,
            "text": "1h",
            "value": "1h"
          },
          {
            "selected": false,
            "text": "1d",
            "value": "1d"
          },
          {
            "selected": false,
            "text": "1w",
            "value": "1w"
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 16,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false
