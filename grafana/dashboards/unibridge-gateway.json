          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(apisix_http_latency_bucket{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[5m])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
