      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(apisix_http_latency_sum{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])) / sum(increase(apisix_http_latency_count{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range]))",
          "datasource": {
