    {
      "id": 23,
      "type": "table",
      "title": "Route Comparison (top 10 by requests)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p50 (ms)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p95 (ms)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Error rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Share"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false
        },
        "sortBy": [
          {
            "displayName": "Requests",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value #A": "Requests",
              "Value #B": "5xx",
              "Value #C": "p50 (ms)",
              "Value #D": "p95 (ms)",
              "Value #E": "Share"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "alias": "Error rate",
            "binary": {
              "left": "5xx",
              "operator": "/",
              "right": "Requests"
            },
            "replaceFields": false
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "(sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\",code=~\"5..\"}[$__range])) or (sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range]))) * 0) and on (route) topk(10, sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        },
        {
          "refId": "C",
          "expr": "(histogram_quantile(0.5, sum by (route, le) (rate(apisix_http_latency_bucket{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))) and on (route) topk(10, sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        },
        {
          "refId": "D",
          "expr": "(histogram_quantile(0.95, sum by (route, le) (rate(apisix_http_latency_bucket{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))) and on (route) topk(10, sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        },
        {
          "refId": "E",
          "expr": "(100 * sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])) / scalar(sum(increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",consumer=~\"$consumer\"}[$__range])))) and on (route) topk(10, sum by (route) (increase(apisix_http_status{route!~\"llm-proxy|llm-messages|llm-responses\",route=~\"$route\",consumer=~\"$consumer\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ]
    },
