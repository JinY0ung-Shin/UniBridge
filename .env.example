# Host IP or hostname that browsers use to access this system
# All service URLs (Keycloak, CORS, redirect URIs) are derived from this + port values below
HOST_IP=localhost

# UniBridge Service
# Meta store. Defaults to the bundled `unibridge-db` Postgres service when left
# unset (required for blue/green — see docs/blue-green-deploy.md). Set
# UNIBRIDGE_DB_PASSWORD below. To keep the legacy file-based SQLite store
# instead, uncomment the line below:
# META_DB_URL=sqlite+aiosqlite:///data/meta.db
UNIBRIDGE_DB_PASSWORD=

# WARNING: Changing ENCRYPTION_KEY after initial setup will invalidate all stored
# database passwords. Back up your data before rotating this key.
# Generate a key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

JWT_SECRET=

# Rate limiting (per user)
RATE_LIMIT_PER_MINUTE=60
MAX_CONCURRENT_QUERIES=5

# NAS / local filesystem read-only provider
# Mount your NAS on the Docker host first, then expose that host path into the
# unibridge-service container. Register NAS base_path values in the UI using the
# container path (for example, /mnt/nas or a child directory under it).
NAS_HOST_PATH=/mnt/nas
NAS_CONTAINER_PATH=/mnt/nas
NAS_ALLOWED_ROOTS=/mnt/nas
NAS_MAX_DOWNLOAD_BYTES=524288000
NAS_MAX_LIST_ENTRIES=5000
NAS_LIST_DEFAULT_LIMIT=500
NAS_STREAM_CHUNK_BYTES=1048576
NAS_MAX_PATH_BYTES=4096
NAS_FS_OP_TIMEOUT_SECONDS=10.0

# S3 / S3-compatible object storage blocking-call isolation
S3_MAX_WORKERS=8
S3_OP_TIMEOUT_SECONDS=30.0
S3_CONNECT_TIMEOUT_SECONDS=5.0
S3_READ_TIMEOUT_SECONDS=30.0

# SSL verification for internal/outgoing HTTPS requests (e.g. unibridge-service → Keycloak JWKS)
# This does not control LiteLLM's external protocol; LiteLLM external access is always HTTPS
# If you use a private CA, prefer setting SSL_CA_CERT_PATH instead of disabling verification
SSL_VERIFY=true
SSL_CA_CERT_PATH=

# CA bundle mount for outbound HTTPS from unibridge-service (e.g. private S3, internal endpoints
# with self-signed / private-CA certificates). HOST_CA_BUNDLE_PATH is bind-mounted read-only into
# the container at CONTAINER_CA_BUNDLE_PATH, and AWS_CA_BUNDLE / REQUESTS_CA_BUNDLE / SSL_CERT_FILE
# are pointed at it so boto3, requests, and stdlib ssl all use it.
# Defaults assume a Debian/Ubuntu Docker host. For RHEL/CentOS use /etc/pki/tls/certs/ca-bundle.crt.
# To disable: set HOST_CA_BUNDLE_PATH to a path that contains only the system defaults you want.
HOST_CA_BUNDLE_PATH=/etc/ssl/certs/ca-certificates.crt
CONTAINER_CA_BUNDLE_PATH=/etc/ssl/certs/ca-certificates.crt

# MSSQL TrustServerCertificate (set to "no" in production)
MSSQL_TRUST_SERVER_CERT=no

# Enable the /auth/token endpoint for development only. Disable in production!
ENABLE_DEV_TOKEN_ENDPOINT=false

# TLS certificates for HTTPS
# Required for HTTPS on Unibridge UI and LiteLLM
TLS_CERT_PATH=./certs/tls.crt
TLS_KEY_PATH=./certs/tls.key

# Ports (change if defaults conflict)
APISIX_PORT=9080
APISIX_SSL_PORT=9443
APISIX_ADMIN_PORT=9180
UNIBRIDGE_SERVICE_PORT=8000
UNIBRIDGE_UI_PORT=3000
LITELLM_PORT=4000
PROMETHEUS_PORT=9090
KEYCLOAK_PORT=8443
# Loopback-only debug bind; users reach Grafana at /grafana on the UI port.
GRAFANA_PORT=3300

# Grafana admin login (dashboards mirroring the UniBridge monitoring UI).
# GRAFANA_ADMIN_PASSWORD is required at boot; GRAFANA_ADMIN_USER defaults to admin.
GRAFANA_ADMIN_PASSWORD=
# Secret for the `grafana` Keycloak client (UniBridge SSO login for Grafana).
# On a fresh install the realm import creates the client with this secret; on
# an existing realm the Keycloak entrypoint auto-creates it at the next boot
# and re-syncs the secret/redirect URI from this value on every boot.
GRAFANA_OAUTH_CLIENT_SECRET=
# Optional Grafana overrides (defaults shown; usually leave unset):
# GRAFANA_ADMIN_USER=admin
# GRAFANA_EXTERNAL_URL=/grafana     # UI-link base if fronted elsewhere
# GRAFANA_UPSTREAM=grafana          # container the UI nginx proxies /grafana to

# Server (host) monitoring — node_exporter scrape job + file_sd targets path.
# Defaults are fine for the bundled stack; see docs/server-monitoring.md.
NODE_EXPORTER_JOB=nodes
# Optional global disk mountpoint default for hosts that do not set their own
# list in the Servers UI. Comma-separated node_exporter mountpoints.
# NODE_EXPORTER_DISK_MOUNTPOINTS=/,/data,/backup
PROMETHEUS_FILE_SD_PATH=/etc/prometheus/file_sd/nodes.json

# Blue/green compose deployment
# The edge proxy owns the public UniBridge HTTPS port. Blue and green UI ports
# are localhost-only verification ports used before promotion.
#
# IMPORTANT: blue/green requires a networked META_DB_URL (e.g. Postgres). Both
# colors share one meta volume, so the default SQLite store is unsafe under two
# concurrent containers. scripts/deploy-bluegreen.sh refuses SQLite unless you
# set ALLOW_SQLITE_BLUEGREEN=true. See docs/blue-green-deploy.md.
# ALLOW_SQLITE_BLUEGREEN=false
# Normal app deployments only verify existing infra so Keycloak, LiteLLM, and
# databases are not unexpectedly recreated. Set true only for a reviewed infra
# update (the first blue/green bootstrap always starts infra).
# RECONCILE_INFRA_ON_DEPLOY=false
UNIBRIDGE_EDGE_PORT=3000
BLUEGREEN_BLUE_UI_PORT=3001
BLUEGREEN_GREEN_UI_PORT=3002
UNIBRIDGE_NETWORK_NAME=unibridge-net
# Defaults match Docker Compose's volume names when this repo is run as project
# "unibridge". Override these if the existing deployment used a different
# COMPOSE_PROJECT_NAME.
UNIBRIDGE_DATA_VOLUME=unibridge_unibridge-data
ETCD_DATA_VOLUME=unibridge_etcd-data
PROMETHEUS_DATA_VOLUME=unibridge_prometheus-data
PROMETHEUS_FILE_SD_VOLUME=unibridge_prometheus-file-sd
KEYCLOAK_DB_DATA_VOLUME=unibridge_keycloak-db-data
LITELLM_DB_DATA_VOLUME=unibridge_litellm-db-data
UNIBRIDGE_DB_DATA_VOLUME=unibridge_unibridge-db-data
GRAFANA_DATA_VOLUME=unibridge_grafana-data
LLM_CONVERTER_STATE_VOLUME=unibridge_llm-converter-state
# Host-reachable APISIX Admin URL for scripts/deploy-bluegreen.sh.
APISIX_ADMIN_HOST_URL=http://127.0.0.1:9180

# APISIX route provisioning. Leave true for the original single-stack compose.
# The blue/green deploy script sets this false for inactive colors and promotes
# APISIX upstreams only after the new color passes health checks.
APISIX_INTERNAL_PROXY_SECRET=
APISIX_PROVISION_ON_START=true
APISIX_UNIBRIDGE_SERVICE_NODE=unibridge-service:8000
APISIX_LLM_CONVERTER_NODE=llm-converter:4001

# LiteLLM Admin UI (separate-origin access)
# LiteLLM external access is always HTTPS
# PROXY_BASE_URL defaults to https://HOST_IP:LITELLM_PORT when unset
# Override only if LiteLLM is published through a different external HTTPS URL:
# PROXY_BASE_URL=https://myhost:4000
# Secret for the `litellm` Keycloak client (UniBridge SSO login for the LiteLLM
# admin UI; admins only). On a fresh install the realm import creates the
# client with this secret; on an existing realm the Keycloak entrypoint
# auto-creates the client, its proxy_admin role, and the realm-admin composite
# at the next boot (see README "LiteLLM admin UI SSO"), and re-syncs the
# secret/redirect URI from env on every boot.
LITELLM_OAUTH_CLIENT_SECRET=

# Required deployment secrets are intentionally left blank in this example.
# After copying to .env, fill them in before first boot.
# Docker Compose fails fast when these are blank or missing:
# - ENCRYPTION_KEY
# - APISIX_ADMIN_KEY
# - KC_ADMIN_PASSWORD
# - KC_DB_PASSWORD
# - UNIBRIDGE_DB_PASSWORD
# - KEYCLOAK_SERVICE_CLIENT_SECRET
# - LITELLM_DB_PASSWORD
# - LITELLM_MASTER_KEY
# - LITELLM_OAUTH_CLIENT_SECRET
# - GRAFANA_ADMIN_PASSWORD
# - GRAFANA_OAUTH_CLIENT_SECRET
#
# Additional values you must also set or verify for normal service operation:
# - ETCD_ROOT_PASSWORD (required unless ETCD_ALLOW_NONE_AUTH=yes for dev)
# - HOST_IP
# - JWT_SECRET (required when not using Keycloak-issued tokens)

# etcd (APISIX config store)
# Required secret. Set a strong password and keep ETCD_ALLOW_NONE_AUTH=no for production.
# For development without auth, set ETCD_ALLOW_NONE_AUTH=yes and leave password empty.
ETCD_ROOT_PASSWORD=
ETCD_ALLOW_NONE_AUTH=no

# APISIX
# Required secret for Docker Compose startup.
APISIX_ADMIN_KEY=

# Keycloak start mode: "true" for dev mode (relaxed security), "false" for production (default)
KEYCLOAK_DEV_MODE=false

# Keycloak web console admin (not used by entrypoint scripts)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=
KC_DB_USER=keycloak
KC_DB_PASSWORD=
KEYCLOAK_REALM=apihub
KEYCLOAK_JWT_AUDIENCE=apihub-ui
# Public browser-facing Keycloak base URL used by the UI runtime config.
# Leave blank to derive https://HOST_IP:KEYCLOAK_PORT at container start.
KEYCLOAK_EXTERNAL_URL=

# Keycloak Service Account (for user management API)
KEYCLOAK_SERVICE_CLIENT_ID=apihub-service
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This secret is shared between Keycloak (realm import) and unibridge-service.
# Both containers must receive the same value.
KEYCLOAK_SERVICE_CLIENT_SECRET=

# LiteLLM (LLM Proxy)
LITELLM_DB_PASSWORD=
# Generate with: python -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"
LITELLM_MASTER_KEY=

# LLM Converter (translates /api/llm/v1/messages -> LiteLLM /v1/chat/completions
# for sglang/vLLM models that don't serve newer endpoints reliably).
# Upstream LiteLLM base URL the converter forwards to (defaults to the in-network
# LiteLLM over HTTPS):
# LITELLM_CONVERTER_UPSTREAM=https://litellm:4000
# CA bundle for the converter->LiteLLM TLS hop. Defaults to the mounted LiteLLM
# self-signed cert (chain validated, hostname check disabled). Set to "" to fall
# back to CONVERTER_TLS_VERIFY:
# CONVERTER_TLS_CA=/etc/ssl/litellm-ca.crt
# Only used when CONVERTER_TLS_CA is empty. true|false|<ca-path> (default false):
# CONVERTER_TLS_VERIFY=false
# Upstream read timeout in seconds; 0 = unbounded (LLM streams are long-lived).
# connect/write/pool timeouts are always bounded regardless, and tunable below:
# CONVERTER_REQUEST_TIMEOUT=0
# CONVERTER_CONNECT_TIMEOUT=10
# CONVERTER_WRITE_TIMEOUT=30
# CONVERTER_POOL_TIMEOUT=10
# previous_response_id store (for /v1/responses chaining): optional SQLite path,
# TTL seconds, max conversations (entry-count LRU), total byte budget (LRU; 0
# disables), and per-entry byte budget (0 disables).
# A chained-off parent is dropped once a follow-up succeeds, so a linear chain
# keeps only its latest transcript. The compose default stores this in a shared
# llm-converter-state volume so restarts and blue/green color swaps keep chains:
# CONVERTER_RESPONSE_STORE_PATH=/var/lib/llm-converter/responses.sqlite3
# CONVERTER_RESPONSE_STORE_TTL=3600
# CONVERTER_RESPONSE_STORE_MAX=10000
# CONVERTER_RESPONSE_STORE_MAX_BYTES=67108864
# CONVERTER_RESPONSE_STORE_MAX_ENTRY_BYTES=16777216
# Surface upstream reasoning_content as Responses reasoning items (true|false):
# CONVERTER_EMIT_REASONING=true

# ---------------------------------------------------------------------------
# Optional package-mirror overrides (for air-gapped / corporate networks)
# Leave blank to use public endpoints. Set per environment in .env only.
# ---------------------------------------------------------------------------
# Replaces http://deb.debian.org inside the unibridge-service build container.
# Example: http://<internal-nexus>/repository/deb-debian-remote
# APT_DEBIAN_MIRROR=

# Root URL for Microsoft packages (used to install msodbcsql18).
# Default public endpoint is https://packages.microsoft.com.
# Example: http://<internal-nexus>/repository/proxy-raw-packages.microsoft.com
# MS_PACKAGES_URL=

# Set to 1 when the MS mirror cannot serve /keys/microsoft.asc (e.g. a raw proxy
# whose allowlist only covers /debian/...). The build then installs msodbcsql18
# with [trusted=yes] instead of signature verification.
# MS_SKIP_GPG=

# pip index URL. When blank, the build falls back to pypi.org with trusted-host flags.
# Example: http://<internal-nexus>/repository/proxy-pypi/simple/
# PIP_INDEX_URL=
# Required when PIP_INDEX_URL is http:// or uses a self-signed cert.
# Example: <internal-nexus>
# PIP_TRUSTED_HOST=

# npm registry for unibridge-ui build. Blank = default registry.npmjs.org.
# Example: http://<internal-nexus>/repository/proxy-npm/
# NPM_REGISTRY=
