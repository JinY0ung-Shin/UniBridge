# Query Service
META_DB_URL=sqlite+aiosqlite:///data/meta.db

# WARNING: Changing ENCRYPTION_KEY after initial setup will invalidate all stored
# database passwords. Back up your data before rotating this key.
# Generate a key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=change-me-to-a-32-byte-key-here!

JWT_SECRET=change-me-to-a-secure-secret

# Rate limiting (per user)
RATE_LIMIT_PER_MINUTE=60
MAX_CONCURRENT_QUERIES=5

# SSL verification for internal outgoing requests (e.g. query-service → Keycloak JWKS)
# Set to false if Keycloak uses a self-signed certificate
# Alternatively, set SSL_CA_CERT_PATH to trust the CA cert while keeping verification on
SSL_VERIFY=true
SSL_CA_CERT_PATH=

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=https://localhost:3000

# MSSQL TrustServerCertificate (set to "no" in production)
MSSQL_TRUST_SERVER_CERT=no

# Enable the /auth/token endpoint for development only. Disable in production!
ENABLE_DEV_TOKEN_ENDPOINT=false

# TLS certificates (for HTTPS)
TLS_CERT_PATH=./certs/tls.crt
TLS_KEY_PATH=./certs/tls.key

# Ports (change if defaults conflict)
APISIX_PORT=9080
APISIX_SSL_PORT=9443
APISIX_ADMIN_PORT=9180
QUERY_SERVICE_PORT=8000
QUERY_UI_PORT=3000
PROMETHEUS_PORT=9090
KEYCLOAK_PORT=8443

# APISIX
APISIX_ADMIN_KEY=CHANGE_ME_TO_A_RANDOM_KEY

# Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
KC_DB_USER=keycloak
KC_DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# KEYCLOAK_EXTERNAL_URL must match the URL the browser uses to access Keycloak
KEYCLOAK_EXTERNAL_URL=https://localhost:8443
KEYCLOAK_ISSUER_URL=https://localhost:8443/realms/apihub
KEYCLOAK_JWKS_URL=https://keycloak:8443/realms/apihub/protocol/openid-connect/certs
KEYCLOAK_JWT_AUDIENCE=apihub-ui

# Keycloak Service Account (for user management API)
KEYCLOAK_URL=https://keycloak:8443
KEYCLOAK_REALM=apihub
KEYCLOAK_SERVICE_CLIENT_ID=apihub-service
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This secret is shared between Keycloak (realm import) and query-service.
# Both containers must receive the same value.
KEYCLOAK_SERVICE_CLIENT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
