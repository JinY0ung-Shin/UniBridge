# Host IP or hostname that browsers use to access this system
# All service URLs (Keycloak, CORS, redirect URIs) are derived from this + port values below
HOST_IP=localhost

# UniBridge Service
META_DB_URL=sqlite+aiosqlite:///data/meta.db

# WARNING: Changing ENCRYPTION_KEY after initial setup will invalidate all stored
# database passwords. Back up your data before rotating this key.
# Generate a key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

JWT_SECRET=

# Rate limiting (per user)
RATE_LIMIT_PER_MINUTE=60
MAX_CONCURRENT_QUERIES=5

# SSL verification for internal/outgoing HTTPS requests (e.g. unibridge-service → Keycloak JWKS)
# This does not control LiteLLM's external protocol; LiteLLM external access is always HTTPS
# If you use a private CA, prefer setting SSL_CA_CERT_PATH instead of disabling verification
SSL_VERIFY=true
SSL_CA_CERT_PATH=

# MSSQL TrustServerCertificate (set to "no" in production)
MSSQL_TRUST_SERVER_CERT=no

# Enable the /auth/token endpoint for development only. Disable in production!
ENABLE_DEV_TOKEN_ENDPOINT=false

# TLS certificates for HTTPS
# Required for HTTPS on Unibridge UI and LiteLLM
TLS_CERT_PATH=./certs/tls.crt
TLS_KEY_PATH=./certs/tls.key

# Ports (change if defaults conflict)
APISIX_PORT=9080
APISIX_SSL_PORT=9443
APISIX_ADMIN_PORT=9180
UNIBRIDGE_SERVICE_PORT=8000
UNIBRIDGE_UI_PORT=3000
LITELLM_PORT=4000
PROMETHEUS_PORT=9090
KEYCLOAK_PORT=8443

# LiteLLM Admin UI (separate-origin access)
# LiteLLM external access is always HTTPS
# PROXY_BASE_URL defaults to https://HOST_IP:LITELLM_PORT when unset
# Override only if LiteLLM is published through a different external HTTPS URL:
# PROXY_BASE_URL=https://myhost:4000

# Required deployment secrets are intentionally left blank in this example.
# After copying to .env, fill them in before first boot.
# Docker Compose fails fast when these are blank or missing:
# - ENCRYPTION_KEY
# - APISIX_ADMIN_KEY
# - KC_ADMIN_PASSWORD
# - KC_DB_PASSWORD
# - KEYCLOAK_SERVICE_CLIENT_SECRET
# - LITELLM_DB_PASSWORD
# - LITELLM_MASTER_KEY
#
# Additional values you must also set or verify for normal service operation:
# - ETCD_ROOT_PASSWORD (required unless ETCD_ALLOW_NONE_AUTH=yes for dev)
# - HOST_IP
# - JWT_SECRET (required when not using Keycloak-issued tokens)

# etcd (APISIX config store)
# Required secret. Set a strong password and keep ETCD_ALLOW_NONE_AUTH=no for production.
# For development without auth, set ETCD_ALLOW_NONE_AUTH=yes and leave password empty.
ETCD_ROOT_PASSWORD=
ETCD_ALLOW_NONE_AUTH=no

# APISIX
# Required secret for Docker Compose startup.
APISIX_ADMIN_KEY=

# Keycloak start mode: "true" for dev mode (relaxed security), "false" for production (default)
KEYCLOAK_DEV_MODE=false

# Keycloak web console admin (not used by entrypoint scripts)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=
KC_DB_USER=keycloak
KC_DB_PASSWORD=
KEYCLOAK_REALM=apihub
KEYCLOAK_JWT_AUDIENCE=apihub-ui

# Keycloak Service Account (for user management API)
KEYCLOAK_SERVICE_CLIENT_ID=apihub-service
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This secret is shared between Keycloak (realm import) and unibridge-service.
# Both containers must receive the same value.
KEYCLOAK_SERVICE_CLIENT_SECRET=

# LiteLLM (LLM Proxy)
LITELLM_DB_PASSWORD=
# Generate with: python -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"
LITELLM_MASTER_KEY=
