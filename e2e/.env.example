# Live E2E config. Copy to `.env` and fill in. `.env` is gitignored.
# Real environment variables override anything set here.

# Required. APISIX consumer key. Tests skip entirely if unset.
LLM_API_KEY=

# Gateway base incl. the /api/llm prefix.
LLM_BASE_URL=https://localhost:3000/api/llm

# APISIX key-auth header carrying the key.
# LLM_API_KEY_HEADER=apikey

# Model id. If unset, discovered from GET /v1/models.
# LLM_MODEL=

# true | false | <ca-path>. UI uses a self-signed cert, so default is false.
LLM_TLS_VERIFY=false

# Per-request timeout (seconds).
# LLM_TIMEOUT=60

# max_tokens for /v1/messages requests. Reasoning models spend budget on a
# thinking block before any answer, so keep this generous.
# LLM_MAX_TOKENS=1024
