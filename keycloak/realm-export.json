{
  "realm": "apihub",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "bruteForceProtected": true,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access to all features",
        "composite": true,
        "composites": { "client": { "litellm": ["proxy_admin"] } }
      },
      { "name": "user", "description": "Monitoring and self-service API key" }
    ],
    "client": {
      "litellm": [
        { "name": "proxy_admin", "description": "LiteLLM Admin UI admin (surfaced as the `role` claim for the litellm client)" }
      ]
    }
  },
  "scopeMappings": [
    {
      "client": "apihub-service",
      "roles": ["admin"]
    }
  ],
  "clients": [
    {
      "clientId": "apihub-service",
      "name": "API Hub Service Account",
      "enabled": true,
      "publicClient": false,
      "secret": "${KEYCLOAK_SERVICE_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "publicClient": false,
      "secret": "${GRAFANA_OAUTH_CLIENT_SECRET}",
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["${GRAFANA_REDIRECT_URI:-https://localhost:3000/grafana/*}"],
      "webOrigins": [],
      "attributes": {"pkce.code.challenge.method": "S256"},
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "litellm",
      "name": "LiteLLM Admin UI",
      "enabled": true,
      "publicClient": false,
      "secret": "${LITELLM_OAUTH_CLIENT_SECRET}",
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["${LITELLM_REDIRECT_URI:-https://localhost:4000/sso/callback}"],
      "webOrigins": [],
      "attributes": {"pkce.code.challenge.method": "S256"},
      "protocolMappers": [
        {
          "name": "litellm role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "usermodel.clientRoleMapping.clientId": "litellm",
            "claim.name": "role",
            "jsonType.label": "String",
            "multivalued": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "apihub-ui",
      "name": "API Hub UI",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["${KEYCLOAK_REDIRECT_URI:-https://localhost:3000/*}"],
      "webOrigins": ["${KEYCLOAK_WEB_ORIGIN:-https://localhost:3000}"],
      "protocolMappers": [
        {
          "name": "apihub-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "apihub-ui-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "apihub-ui",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-apihub-service",
      "enabled": true,
      "serviceAccountClientId": "apihub-service",
      "clientRoles": {
        "realm-management": ["view-users", "manage-users", "view-realm", "manage-clients"]
      }
    }
  ]
}
